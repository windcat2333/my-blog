---
const API_BASE = 'https://blog-api.windcat952.workers.dev';
const { slug } = Astro.props;
---

<div id="comments" data-slug={slug} data-api={API_BASE}>
	<h3 class="comments-title">// comments</h3>
	<div id="comment-list"></div>
	<form id="comment-form">
		<div class="form-row">
			<span class="form-prompt">$</span>
			<input type="text" id="comment-author" placeholder="你的昵称" required maxlength="50" />
		</div>
		<div class="form-row form-area">
			<span class="form-prompt">»</span>
			<textarea id="comment-content" placeholder="写下你的评论..." required maxlength="5000" rows="4"></textarea>
		</div>
		<button type="submit">发表评论</button>
	</form>
	<p id="comment-status"></p>
</div>
<script>
	const container = document.getElementById('comments');
	const slug = container.dataset.slug;
	const api = container.dataset.api;

	async function loadComments() {
		const res = await fetch(`${api}/api/comments?slug=${slug}`);
		const comments = await res.json();
		const list = document.getElementById('comment-list');
		if (comments.length === 0) {
			list.innerHTML = '<p class="empty-comments">/* 暂无评论，来说两句吧 */</p>';
			return;
		}
		list.innerHTML = comments.map(c => `
			<div class="comment">
				<div class="comment-meta">
					<strong class="comment-author">${escapeHtml(c.author)}</strong>
					<span class="comment-date">${new Date(c.created_at).toLocaleDateString('zh-CN')}</span>
				</div>
				<div class="comment-content">${escapeHtml(c.content).replace(/\n/g, '<br>')}</div>
			</div>
		`).join('');
	}

	function escapeHtml(text) {
		const d = document.createElement('div');
		d.textContent = text;
		return d.innerHTML;
	}

	document.getElementById('comment-form').addEventListener('submit', async (e) => {
		e.preventDefault();
		const author = document.getElementById('comment-author').value.trim();
		const content = document.getElementById('comment-content').value.trim();
		const status = document.getElementById('comment-status');
		if (!author || !content) return;
		status.textContent = '// 发表中...';
		try {
			const res = await fetch(`${api}/api/comments`, {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({ slug, author, content }),
			});
			if (!res.ok) {
				const err = await res.json();
				status.textContent = `// 失败：${err.error}`;
				return;
			}
			document.getElementById('comment-author').value = '';
			document.getElementById('comment-content').value = '';
			status.textContent = '// 评论成功！';
			loadComments();
		} catch {
			status.textContent = '// 网络错误，请重试';
		}
	});

	loadComments();
</script>
<style>
	#comments {
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid var(--border);
	}
	.comments-title {
		font-family: var(--font-mono);
		font-size: 1.1em;
		color: var(--text-secondary);
		margin-bottom: 1em;
		border: none;
	}

	.empty-comments {
		font-family: var(--font-mono);
		font-size: 0.9em;
		color: var(--text-secondary);
		padding: 1em;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 8px;
		text-align: center;
	}

	.comment {
		padding: 0.8em 1em;
		margin-bottom: 0.5em;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 8px;
	}
	.comment-meta {
		margin-bottom: 0.3em;
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.comment-author {
		font-family: var(--font-mono);
		color: var(--accent);
	}
	.comment-date {
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--text-secondary);
	}
	.comment-content {
		font-size: 0.9em;
		line-height: 1.6;
	}

	#comment-form {
		max-width: 500px;
	}
	.form-row {
		display: flex;
		align-items: flex-start;
		gap: 0.5em;
		margin-bottom: 0.5em;
	}
	.form-prompt {
		font-family: var(--font-mono);
		color: var(--accent);
		font-size: 0.95em;
		padding-top: 0.5em;
		flex-shrink: 0;
	}
	#comment-form input,
	#comment-form textarea {
		flex: 1;
		padding: 0.5em 0.75em;
		border: 1px solid var(--border);
		border-radius: 6px;
		font-size: 0.9em;
		font-family: var(--font-mono);
		background: var(--bg);
		color: var(--text);
	}
	#comment-form input:focus,
	#comment-form textarea:focus {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 2px rgba(63, 185, 80, 0.15);
	}
	#comment-form button {
		font-family: var(--font-mono);
		font-size: 0.85em;
		padding: 0.5em 1.2em;
		background: var(--accent);
		color: #fff;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		transition: background 0.15s;
	}
	#comment-form button:hover {
		background: var(--accent-hover);
	}
	#comment-status {
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--text-secondary);
		margin-top: 0.5em;
	}
</style>
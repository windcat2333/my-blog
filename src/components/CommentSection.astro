---
const API_BASE = 'https://blog-api.windcat952.workers.dev';
const { slug } = Astro.props;
---

<div id="comments" data-slug={slug} data-api={API_BASE}>
	<h3>评论</h3>
	<div id="comment-list"></div>
	<form id="comment-form">
		<input type="text" id="comment-author" placeholder="你的昵称" required maxlength="50" />
		<textarea id="comment-content" placeholder="写下你的评论..." required maxlength="5000" rows="4"></textarea>
		<button type="submit">发表评论</button>
	</form>
	<p id="comment-status"></p>
</div>
<script>
	const container = document.getElementById('comments');
	const slug = container.dataset.slug;
	const api = container.dataset.api;

	async function loadComments() {
		const res = await fetch(`${api}/api/comments?slug=${slug}`);
		const comments = await res.json();
		const list = document.getElementById('comment-list');
		if (comments.length === 0) {
			list.innerHTML = '<p style="color:rgb(var(--gray))">暂无评论，来说两句吧</p>';
			return;
		}
		list.innerHTML = comments.map(c => `
			<div class="comment">
				<div class="comment-meta">
					<strong>${escapeHtml(c.author)}</strong>
					<span class="comment-date">${new Date(c.created_at).toLocaleDateString('zh-CN')}</span>
				</div>
				<div class="comment-content">${escapeHtml(c.content).replace(/\n/g, '<br>')}</div>
			</div>
		`).join('');
	}

	function escapeHtml(text) {
		const d = document.createElement('div');
		d.textContent = text;
		return d.innerHTML;
	}

	document.getElementById('comment-form').addEventListener('submit', async (e) => {
		e.preventDefault();
		const author = document.getElementById('comment-author').value.trim();
		const content = document.getElementById('comment-content').value.trim();
		const status = document.getElementById('comment-status');
		if (!author || !content) return;
		status.textContent = '发表中...';
		try {
			const res = await fetch(`${api}/api/comments`, {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({ slug, author, content }),
			});
			if (!res.ok) {
				const err = await res.json();
				status.textContent = `失败：${err.error}`;
				return;
			}
			document.getElementById('comment-author').value = '';
			document.getElementById('comment-content').value = '';
			status.textContent = '评论成功！';
			loadComments();
		} catch {
			status.textContent = '网络错误，请重试';
		}
	});

	loadComments();
</script>
<style>
	#comments { margin-top: 3em; padding-top: 1em; border-top: 1px solid rgb(var(--gray-light)); }
	#comments h3 { margin-bottom: 1em; }
	#comment-form { display: flex; flex-direction: column; gap: 0.5em; max-width: 500px; }
	#comment-form input, #comment-form textarea {
		padding: 0.5em; border: 1px solid rgb(var(--gray-light)); border-radius: 4px;
		font-size: 1em; font-family: inherit;
		background: var(--bg); color: rgb(var(--gray-dark));
	}
	#comment-form button {
		padding: 0.5em 1em; background: var(--accent); color: white;
		border: none; border-radius: 4px; cursor: pointer; font-size: 1em;
		align-self: flex-start;
	}
	#comment-form button:hover { opacity: 0.85; }
	#comment-status { color: rgb(var(--gray)); font-size: 0.9em; }
	.comment { padding: 0.8em 0; border-bottom: 1px solid rgb(var(--gray-light)); }
	.comment-meta { margin-bottom: 0.3em; }
	.comment-date { color: rgb(var(--gray)); font-size: 0.85em; margin-left: 0.5em; }
	.comment-content { line-height: 1.5; }
</style>

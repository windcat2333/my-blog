---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span class="footer-copy">&copy; {today.getFullYear()} {SITE_TITLE}</span>
		<span class="footer-powered">
			Built with <a href="https://astro.build" target="_blank">Astro</a>
			&middot;
			Hosted on <a href="https://pages.cloudflare.com" target="_blank">Cloudflare Pages</a>
		</span>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2em 1.5em;
		margin-top: 2em;
	}
	.footer-inner {
		max-width: 780px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.85em;
		color: var(--text-secondary);
	}
	.footer-powered a {
		color: var(--text-secondary);
	}
	.footer-powered a:hover {
		color: var(--accent);
	}
	@media (max-width: 600px) {
		.footer-inner { flex-direction: column; gap: 0.3em; text-align: center; }
	}
</style>
---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/blog/tags/">标签</HeaderLink>
			<HeaderLink href="/search">搜索</HeaderLink>
		</div>
		<div class="nav-actions">
			<ThemeToggle />
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(13, 17, 23, 0.75);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	html:not(.dark) header {
		background: rgba(255, 255, 255, 0.8);
	}
	nav {
		max-width: 780px;
		margin: 0 auto;
		padding: 0 1.5em;
		display: flex;
		align-items: center;
		gap: 1.5em;
	}
	.site-title {
		font-family: var(--font-mono);
		font-size: 1.1em;
		font-weight: 700;
		color: var(--text) !important;
		text-decoration: none !important;
		padding: 0.9em 0;
		margin-right: auto;
	}
	.site-title::before {
		content: './';
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 0.25em;
	}
	.nav-links :global(a) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		padding: 0.9em 0.7em;
		color: var(--text-secondary);
		text-decoration: none !important;
		border-bottom: 2px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}
	.nav-links :global(a:hover) {
		color: var(--text);
	}
	.nav-links :global(a.active) {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	.nav-actions {
		display: flex;
		align-items: center;
	}
	@media (max-width: 600px) {
		.nav-links { gap: 0; }
		.nav-links :global(a) { padding: 0.9em 0.5em; font-size: 0.8em; }
		.site-title { font-size: 1em; }
	}
</style>
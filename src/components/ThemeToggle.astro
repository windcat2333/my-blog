<button id="theme-toggle" title="切换暗色模式" aria-label="切换暗色模式">
	<svg id="sun-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
		<circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
	</svg>
	<svg id="moon-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
	</svg>
</button>
<script>
	const toggle = document.getElementById('theme-toggle');
	const sun = document.getElementById('sun-icon');
	const moon = document.getElementById('moon-icon');
	const stored = localStorage.getItem('theme');
	if (stored === 'dark' || (!stored && matchMedia('(prefers-color-scheme: dark)').matches)) {
		document.body.classList.add('dark');
		sun.style.display = 'none';
		moon.style.display = '';
	}
	toggle.addEventListener('click', () => {
		document.body.classList.toggle('dark');
		const isDark = document.body.classList.contains('dark');
		sun.style.display = isDark ? 'none' : '';
		moon.style.display = isDark ? '' : 'none';
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
	});
</script>
<style>
	#theme-toggle {
		background: none; border: none; cursor: pointer;
		color: rgb(var(--gray)); padding: 0.5em;
		display: flex; align-items: center;
	}
	#theme-toggle:hover { color: var(--accent); }
</style>

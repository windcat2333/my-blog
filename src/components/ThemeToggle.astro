<button id="theme-toggle" title="切换暗色模式" aria-label="切换暗色模式">
	<svg id="sun-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
	</svg>
	<svg id="moon-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
	</svg>
</button>
<script>
	const toggle = document.getElementById('theme-toggle');
	const sun = document.getElementById('sun-icon');
	const moon = document.getElementById('moon-icon');
	function syncIcons() {
		const isDark = document.documentElement.classList.contains('dark');
		sun.style.display = isDark ? 'none' : '';
		moon.style.display = isDark ? '' : 'none';
	}
	syncIcons();
	toggle.addEventListener('click', () => {
		document.documentElement.classList.toggle('dark');
		syncIcons();
		localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
	});
</script>
<style>
	#theme-toggle {
		background: none;
		border: 1px solid var(--border);
		border-radius: 6px;
		cursor: pointer;
		color: var(--text-secondary);
		padding: 0.45em 0.5em;
		display: flex;
		align-items: center;
		transition: color 0.15s, border-color 0.15s;
	}
	#theme-toggle:hover {
		color: var(--text);
		border-color: var(--text-secondary);
	}
</style>
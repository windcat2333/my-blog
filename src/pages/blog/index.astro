---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`博客 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">/posts</h1>

			<div class="post-list">
				{posts.map((post) => (
					<article class="post-card">
						<a href={`/blog/${post.id}/`} class="post-link">
							<div class="post-meta">
								<span class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
								{post.data.tags && post.data.tags.length > 0 && (
									<span class="post-tags">
										{post.data.tags.map((tag) => (
											<span class="tag">{tag}</span>
										))}
									</span>
								)}
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-desc">{post.data.description}</p>
							<span class="post-read">read more →</span>
						</a>
					</article>
				))}
				{posts.length === 0 && (
					<p class="empty-state"># 暂无文章，敬请期待</p>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
<style>
	.page-title {
		font-size: 1.8em;
		margin-bottom: 1.5em;
		border: none;
	}
	.page-title::before {
		content: '$ ';
		color: var(--accent);
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	.post-card {
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: border-color 0.15s, background 0.15s;
	}
	.post-card:hover {
		border-color: var(--accent);
		background: var(--bg-secondary);
	}

	.post-link {
		display: block;
		padding: 1.2em 1.5em;
		text-decoration: none !important;
	}

	.post-meta {
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--text-secondary);
		margin-bottom: 0.4em;
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-wrap: wrap;
	}
	.post-date {
		color: var(--orange);
	}
	.tag {
		display: inline-block;
		padding: 0.1em 0.45em;
		font-size: 0.85em;
		background: var(--bg-tertiary);
		color: var(--blue);
		border: 1px solid var(--border);
		border-radius: 4px;
	}

	.post-title {
		font-family: var(--font-mono);
		font-size: 1.2em;
		font-weight: 600;
		color: var(--text);
		margin: 0 0 0.3em;
		border: none;
	}
	.post-card:hover .post-title {
		color: var(--accent);
	}

	.post-desc {
		font-size: 0.9em;
		color: var(--text-secondary);
		margin: 0 0 0.5em;
	}

	.post-read {
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--blue);
	}
	.post-card:hover .post-read {
		color: var(--accent);
	}

	.empty-state {
		font-family: var(--font-mono);
		color: var(--text-secondary);
		padding: 2em;
		text-align: center;
	}
</style>
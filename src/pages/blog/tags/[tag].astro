---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
	return tags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.params;
const posts = (await getCollection('blog'))
	.filter((p) => p.data.tags.includes(tag!))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${tag} - ${SITE_TITLE}`} description={`标签：${tag}`} />
	</head>
	<body>
		<Header />
		<main>
			<p class="back-link"><a href="/blog/tags/">← all tags</a></p>
			<h1 class="page-title">/tags/{tag}</h1>

			<div class="post-list">
				{posts.map((post) => (
					<article class="post-card">
						<a href={`/blog/${post.id}/`} class="post-link">
							<div class="post-meta">
								<span class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-desc">{post.data.description}</p>
						</a>
					</article>
				))}
				{posts.length === 0 && (
					<p class="empty"># 该标签下暂无文章</p>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
<style>
	.back-link {
		font-family: var(--font-mono);
		font-size: 0.85em;
		margin-bottom: 0.5em;
	}
	.back-link a {
		color: var(--text-secondary);
	}
	.back-link a:hover {
		color: var(--accent);
	}

	.page-title {
		font-size: 1.8em;
		margin-bottom: 1.5em;
		border: none;
	}
	.page-title::before {
		content: '$ ';
		color: var(--accent);
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	.post-card {
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: border-color 0.15s, background 0.15s;
	}
	.post-card:hover {
		border-color: var(--accent);
		background: var(--bg-secondary);
	}

	.post-link {
		display: block;
		padding: 1em 1.5em;
		text-decoration: none !important;
	}

	.post-meta {
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--text-secondary);
		margin-bottom: 0.3em;
	}
	.post-date {
		color: var(--orange);
	}

	.post-title {
		font-family: var(--font-mono);
		font-size: 1.1em;
		font-weight: 600;
		color: var(--text);
		margin: 0 0 0.2em;
		border: none;
	}
	.post-card:hover .post-title {
		color: var(--accent);
	}

	.post-desc {
		font-size: 0.85em;
		color: var(--text-secondary);
		margin: 0;
	}

	.empty {
		font-family: var(--font-mono);
		color: var(--text-secondary);
		text-align: center;
		padding: 2em;
	}
</style>